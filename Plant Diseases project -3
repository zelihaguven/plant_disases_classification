)\n","\n","baseline_model.summary()"]},{"cell_type":"code","execution_count":null,"metadata":{"id":"atMe39HCW7zZ"},"outputs":[],"source":["# BASELINE MODEL OBSERVATIONS:\n","# - Dense layer alone has 25.6M parameters — extremely large for our dataset\n","# - Total 25.7M parameters trained on only 1322 images — high overfitting risk\n","# - This is expected for a baseline CNN from scratch\n","# - These results will justify why we move to Transfer Learning:\n","#   pre-trained models already know edges, textures, shapes\n","#   so they need far fewer parameters to fine-tune for our specific task"]},{"cell_type":"code","execution_count":null,"metadata":{"colab":{"background_save":true,"base_uri":"https://localhost:8080/"},"id":"2UQXRdfyXCXa","outputId":"64f9c700-9456-407c-dd66-664d0a4780e9"},"outputs":[{"name":"stdout","output_type":"stream","text":["Epoch 1/30\n","\u001b[1m42/42\u001b[0m \u001b[32m━━━━━━━━━━━━━━━━━━━━\u001b[0m\u001b[37m\u001b[0m \u001b[1m324s\u001b[0m 7s/step - accuracy: 0.6808 - loss: 11.6044 - val_accuracy: 0.6333 - val_loss: 10.3834\n","Epoch 2/30\n","\u001b[1m42/42\u001b[0m \u001b[32m━━━━━━━━━━━━━━━━━━━━\u001b[0m\u001b[37m\u001b[0m \u001b[1m318s\u001b[0m 8s/step - accuracy: 0.8026 - loss: 1.2543 - val_accuracy: 0.5500 - val_loss: 3.5844\n","Epoch 3/30\n","\u001b[1m42/42\u001b[0m \u001b[32m━━━━━━━━━━━━━━━━━━━━\u001b[0m\u001b[37m\u001b[0m \u001b[1m307s\u001b[0m 7s/step - accuracy: 0.8177 - loss: 0.6363 - val_accuracy: 0.8333 - val_loss: 0.8532\n","Epoch 4/30\n","\u001b[1m42/42\u001b[0m \u001b[32m━━━━━━━━━━━━━━━━━━━━\u001b[0m\u001b[37m\u001b[0m \u001b[1m316s\u001b[0m 7s/step - accuracy: 0.8457 - loss: 0.5133 - val_accuracy: 0.7000 - val_loss: 1.0119\n","Epoch 5/30\n","\u001b[1m42/42\u001b[0m \u001b[32m━━━━━━━━━━━━━━━━━━━━\u001b[0m\u001b[37m\u001b[0m \u001b[1m308s\u001b[0m 7s/step - accuracy: 0.8676 - loss: 0.4394 - val_accuracy: 0.9333 - val_loss: 0.7032\n","Epoch 6/30\n","\u001b[1m42/42\u001b[0m \u001b[32m━━━━━━━━━━━━━━━━━━━━\u001b[0m\u001b[37m\u001