pan style=\"color: #00af00; text-decoration-color: #00af00\">164,355</span> (642.01 KB)\n","</pre>\n"],"text/plain":["\u001b[1m Trainable params: \u001b[0m\u001b[38;5;34m164,355\u001b[0m (642.01 KB)\n"]},"metadata":{},"output_type":"display_data"},{"data":{"text/html":["<pre style=\"white-space:pre;overflow-x:auto;line-height:normal;font-family:Menlo,'DejaVu Sans Mono',consolas,'Courier New',monospace\"><span style=\"font-weight: bold\"> Non-trainable params: </span><span style=\"color: #00af00; text-decoration-color: #00af00\">4,049,571</span> (15.45 MB)\n","</pre>\n"],"text/plain":["\u001b[1m Non-trainable params: \u001b[0m\u001b[38;5;34m4,049,571\u001b[0m (15.45 MB)\n"]},"metadata":{},"output_type":"display_data"}],"source":["# ============================================================\n","# TRANSFER LEARNING — EfficientNetB0\n","# ============================================================\n","\n","# WHAT IS TRANSFER LEARNING:\n","# Instead of training a model from scratch, we take a model that was already\n","# trained on a large dataset (ImageNet — 14 million images, 1000 classes)\n","# and fine-tune it for our specific problem.\n","# The model already knows how to detect edges, textures, shapes — we just\n","# teach it to distinguish between Healthy, Powdery, and Rust leaves.\n","\n","# WHY EFFICIENTNETB0:\n","# EfficientNet was designed to be both accurate AND efficient.\n","# It scales depth, width, and resolution of the network together (compound scaling)\n","# achieving better accuracy with fewer parameters than older architectures.\n","# EfficientNetB0 is the smallest version — perfect for our small dataset (1322 images).\n","# Our project goal is \"performant yet efficient\" — EfficientNet directly addresses this.\n","\n","# HOW WE USE IT:\n","# 1. Load EfficientNetB0 pre-trained on ImageNet (without the top classifier layer)\n","# 2. Freeze the base model — keep ImageNet weights, don't update them\n","# 3. Add our own classifier on top (Dense layers for 3 classes)\n","# 4. Train only our top layers first\n","# 5. Later we can unfreeze some layers for fine-tuning (optional)\n","\n","from tensorflow.keras.applications import EfficientNetB0\n","from tensorflow.keras.models import Model\n","from tensorflow.keras.layers import GlobalAveragePooling2D, Dense, Dropout, Input\n","\n","# Load pre-trained base model\n","base_model = EfficientNetB0(\n","    weights='imagenet',     # use ImageNet pre-trained weights\n","    include_top=False,      # remove the original classifier\n","    input_shape=(224, 224, 3)\n",")\n","\n","# Freeze base model — don't update pre-trained weights\n","base_model.trainable = False\n","\n","# Build our classifier on top\n","inputs = Input(shape=(224, 224, 3))\n","x = base_model(inputs, training=False)\n","x = GlobalAveragePooling2D()(x)\n","x = Dropout(0.3)(x)\n","x = Dense(128, activation='relu')(x)\n","x = Dropout(0.3)(x)\n","outputs = Dense(3, activation='softmax')(x)\n","\n","efficientnet_model = Model(inputs, outputs)\n","\n","efficientnet_model.compile(\n","    optimizer='adam',\n","    loss='categorical_crossentropy',\n","    metrics=['accuracy']\n",")\n","\n","efficientnet_model.summary()"]},{"cell_type":"code","execution_count":null,"metadata":{"colab":{"background_save":true},"id":"ztZntZuAtlHv"},"outputs":[],"source":["# EFFICIENTNETB0 vs BASELINE CNN — KEY OBSERVATIONS:\n","# - EfficientNet only trains 164K parameters — just 0.6% of the baseline's 25.7M\n","# - The remaining 4M parameters come frozen from ImageNet pre-training\n","# - This makes it significantly smaller (16MB vs 98MB) and more efficient\n","# - Fewer trainable parameters = less overfitting risk on our small dataset\n","# - This directly addresses the project goal: \"performant yet efficient\"\n","# - We expect better accuracy with a fraction of the computational cost"]},{"cell_type":"code","execution_count":null,"metadata":{"colab":{"background_save":true},"id":"z__UuQ7ptnK0","outputId":"e79f58f0-44f7-4612-f99a-