{"cells":[{"cell_type":"code","execution_count":null,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"elapsed":9745,"status":"ok","timestamp":1778229652329,"user":{"displayName":"ılgın güven","userId":"06815047185075290235"},"user_tz":-120},"id":"RZl9h934Snpr","outputId":"fe13ee4d-691c-415e-e439-79c30ce1cdc4"},"outputs":[{"name":"stdout","output_type":"stream","text":["Using Colab cache for faster access to the 'plant-disease-recognition-dataset' dataset.\n","Dataset ready!\n","\n","Train dir: /kaggle/input/plant-disease-recognition-dataset/Train/Train\n","Val dir:   /kaggle/input/plant-disease-recognition-dataset/Validation/Validation\n","Test dir:  /kaggle/input/plant-disease-recognition-dataset/Test/Test\n"]}],"source":["# ============================================================\n","# PLANT DISEASE CLASSIFIER\n","# Dataset: Plant Disease Recognition Dataset (Kaggle)\n","# Classes: Healthy, Powdery, Rust\n","# ============================================================\n","\n","# SETUP\n","!pip install kagglehub -q\n","\n","import kagglehub\n","import os\n","import numpy as np\n","import matplotlib.pyplot as plt\n","from PIL import Image\n","import random\n","\n","# Download dataset\n","path = kagglehub.dataset_download(\"rashikrahmanpritom/plant-disease-recognition-dataset\")\n","print(\"Dataset ready!\")\n","\n","# Define paths\n","train_dir = os.path.join(path, 'Train', 'Train')\n","val_dir   = os.path.join(path, 'Validation', 'Validation')\n","test_dir  = os.path.join(path, 'Test', 'Test')\n","classes   = ['Healthy', 'Powdery', 'Rust']\n","\n","print(f\"\\nTrain dir: {train_dir}\")\n","print(f\"Val dir:   {val_dir}\")\n","print(f\"Test dir:  {test_dir}\")"]},{"cell_type":"code","execution_count":null,"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":907},"executionInfo":{"elapsed":920,"status":"ok","timestamp":1778229653259,"user":{"displayName":"ılgın güven","userId":"06815047185075290235"},"user_tz":-120},"id":"Jnw-Tb0iTLiG","outputId":"52c186cc-2f11-4bee-c5ae-8ca03619876d"},"outputs":[{"name":"stdout","output_type":"stream","text":["=============================================\n","CLASS DISTRIBUTION PER SPLIT\n","=============================================\n","\n","Train:\n","  Healthy: 458 images\n","  Powdery: 430 images\n","  Rust: 434 images\n","\n","Validation:\n","  Healthy: 20 images\n","  Powdery: 20 images\n","  Rust: 20 images\n","\n","Test:\n","  Healthy: 50 images\n","  Powdery: 50 images\n","  Rust: 50 images\n"]},{"data":{"image/png":"\n","text/plain":["<Figure size 1000x600 with 1 Axes>"]},"metadata":{},"output_type":"display_data"}],"source":["# ============================================================\n","# EDA — EXPLORATORY DATA ANALYSIS\n","# ============================================================\n","\n","# WHY EDA:\n","# Before building any model, we need to deeply understand our data.\n","# Jumping straight into modeling without exploring the data leads to poor decisions\n","# that are hard to justify later. EDA answers critical questions:\n","#   - How many samples do we have per class? (class balance → metric choice)\n","#   - What do the images actually look like? (visual complexity → model choice)\n","#   - What sizes are the images? (preprocessing decisions → resize strategy)\n","\n","# --- 1. CLASS DISTRIBUTION ---\n","# WHY: Check if classes are balanced → determines which metric to use\n","# If balanced → accuracy is valid. If imbalanced → F1 score is more reliable.\n","\n","print(\"=\" * 45)\n","print(\"CLASS DISTRIBUTION PER SPLIT\")\n","print(\"=\" * 45)\n","\n","counts = {}\n","for split_name, split_dir in [('Train', train_dir), ('Validation', val_dir), ('Test', test_dir)]:\n","    print(f\"\\n{split_name}:\")\n","    counts[split_name] = {}\n","    for cls in classes:\n","        cls_path = os.path.join(split_dir, cls)\n","        count = len([f for f in os.listdir(cls_path)\n","                     if f.lower().endswith(('.jpg', '.jpeg', '.png'))])\n","        counts[split_name][cls] = count\n","        print(f\"  {cls}: {count} images\")\n","\n","# Bar chart\n","splits = ['Train', 'Validation', 'Test']\n","healthy = [counts[s]['Healthy'] for s in splits]\n","powdery = [counts[s]['Powdery'] for s in splits]\n","rust    = [counts[s]['Rust']    for s in splits]\n","\n","x = np.arange(len(splits))\n","width = 0.25\n","\n","fig, ax = plt.subplots(figsize=(10, 6))\n","bars1 = ax.bar(x - width, healthy, width, label='Healthy', color='green',  alpha=0.7)\n","bars2 = ax.bar(x,          powdery, width, label='Powdery', color='orange', alpha=0.7)\n","bars3 = ax.bar(x + width,  rust,    width, label='Rust',    color='red',    alpha=0.7)\n","\n","for bar in [bars1, bars2, bars3]:\n","    for rect in bar:\n","        height = rect.get_height()\n","        ax.annotate(f'{height}',\n","                    xy=(rect.get_x() + rect.get_width() / 2, height),\n","                    xytext=(0, 3), textcoords=\"offset points\",\n","                    ha='center', va='bottom')\n","\n","ax.set_xlabel('Dataset Split')\n","ax.set_ylabel('Number of Images')\n","ax.set_title('Class Distribution per Split')\n","ax.set_xticks(x)\n","ax.set_xticklabels(splits)\n","ax.legend()\n","plt.tight_layout()\n","plt.show()\n","\n","# WHY ACCURACY:\n","# Classes are balanced (458/430/434 in train) so accuracy is a reliable metric.\n","# We also add F1-score as a supporting metric for completeness.\n","\n","# WHY NOT ROC-AUC:\n","# ROC-AUC is powerful for binary classification.\n","# For 3 classes it requires macro/weighted averaging — harder to interpret.\n","# Not necessary when classes are balanced.\n","\n","# NOTE — Validation set is very small (only 60 images, 20 per class).\n","# This means we cannot fully trust validation results alone.\n","# We will address this later with K-Fold Cross Validation."]},{"cell_type":"code","execution_count":null,"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":562},"executionInfo":{"elapsed":23576,"status":"ok","timestamp":1778229676836,"user":{"displayName":"ılgın güven","userId":"06815047185075290235"},"user_tz":-120},"id":"Wut90bQ-TcFh","outputId":"d243b4e1-0f60-4ff6-88a9-985346b5fdaf"},"outputs":[{"data":{"image/png":"\n","text/plain":["<Figure size 1500x900 with 15 Axes>"]},"metadata":{},"output_type":"display_data"}],"source":["# --- 2. SAMPLE IMAGES PER CLASS ---\n","# WHY: Visually understand how different the classes look.\n","# This helps us understand the difficulty of the classification problem\n","# and justify our model and augmentation choices.\n","\n","fig, axes = plt.subplots(3, 5, figsize=(15, 9))\n","\n","for row, cls in enumerate(classes):\n","    cls_images = []\n","    for split_dir in [train_dir, val_dir, test_dir]:\n","        cls_path = os.path.join(split_dir, cls)\n","        imgs = [os.path.join(cls_path, f) for f in os.listdir(cls_path)\n","                if f.lower().endswith(('.jpg', '.jpeg', '.png'))]\n","        cls_images.extend(imgs)\n","\n","    samples = random.sample(cls_images, 5)\n","\n","    for col, img_path in enumerate(samples):\n","        img = Image.open(img_path)\n","        axes[row, col].imshow(img)\n","        axes[row, col].axis('off')\n","        if col == 0:\n","            axes[row, col].set_title(cls, fontsize=12, fontweight='bold', loc='left')\n","\n","plt.suptitle('Sample Images per Class', fontsize=14)\n","plt.tight_layout()\n","plt.show()\n","\n"]},{"cell_type":"code","execution_count":null,"metadata":{"id":"ZMKjtD1NTpoE"},"outputs":[],"source":["# VISUAL ANALYSIS NOTES:\n","# - Rust is visually the most distinct class (orange/red spots) — model will likely learn this easily\n","# - Healthy and Powdery are the most similar visually — both green leaves,\n","#   Powdery just has a white/grey powder coating on the surface\n","# - The main confusion will likely be between Healthy and Powdery\n","#   we will track this closely in the Confusion Matrix\n","# - Since Powdery mildew is a texture-based disease, CNN is a strong choice\n","#   as CNNs are specifically good at capturing local texture patterns\n","# - Pre-trained models already learned texture features from ImageNet\n","#   so Transfer Learning gives us a strong advantage with our limited dataset"]},{"cell_type":"code","execution_count":null,"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":745},"executionInfo":{"elapsed":8668,"status":"ok","timestamp":1778229685517,"user":{"displayName":"ılgın güven","userId":"06815047185075290235"},"user_tz":-120},"id":"_7LH1o76UbsM","outputId":"55d87c49-4256-4b1a-b5f3-8595238863d5"},"outputs":[{"name":"stdout","output_type":"stream","text":["Total images checked: 1532\n","\n","Width  — min: 2421, max: 5184, mean: 3986\n","Height — min: 1728, max: 3456, mean: 2702\n","\n","Unique sizes (8):\n","  (4000, 2672) — 93a7c1dd2fe04f20.jpg\n","  (4000, 3000) — 80aaeaaa275d5e36.jpg\n","  (2421, 2279) — 8ceaba5894836ee9.jpg\n","  (2592, 1728) — a5d042c32bc737ab.jpg\n","  (4608, 3456) — adecc8c68c55d855.jpg\n","  (5184, 3456) — bd96b091cdcc7c48.jpg\n","  (4032, 3024) — aa542048ebf78bf4.jpg\n","  (3901, 2607) — 8e68163c62dc57d5.jpg\n"]},{"data":{"image/png":"\n","text/plain":["<Figure size 800x500 with 1 Axes>"]},"metadata":{},"output_type":"display_data"}],"source":["# --- 3. IMAGE SIZE ANALYSIS ---\n","# WHY: Images may have different sizes and resolutions.\n","# We need to know this to make an informed decision about resizing strategy.\n","# Without checking, we don't know if aspect ratios vary or how much information\n","# we lose when resizing.\n","\n","sizes = []\n","size_to_path = {}\n","\n","for split_dir in [train_dir, val_dir, test_dir]:\n","    for cls in classes:\n","        cls_path = os.path.join(split_dir, cls)\n","        for f in os.listdir(cls_path):\n","            if f.lower().endswith(('.jpg', '.jpeg', '.png')):\n","                img_path = os.path.join(cls_path, f)\n","                img = Image.open(img_path)\n","                sizes.append(img.size)\n","                if img.size not in size_to_path:\n","                    size_to_path[img.size] = img_path\n","\n","widths  = [s[0] for s in sizes]\n","heights = [s[1] for s in sizes]\n","\n","print(f\"Total images checked: {len(sizes)}\")\n","print(f\"\\nWidth  — min: {min(widths)}, max: {max(widths)}, mean: {int(sum(widths)/len(widths))}\")\n","print(f\"Height — min: {min(heights)}, max: {max(heights)}, mean: {int(sum(heights)/len(heights))}\")\n","print(f\"\\nUnique sizes ({len(set(sizes))}):\")\n","for size, path in size_to_path.items():\n","    print(f\"  {size} — {os.path.basename(path)}\")\n","\n","# Scatter plot\n","plt.figure(figsize=(8, 5))\n","plt.scatter(widths, heights, alpha=0.3, color='steelblue')\n","plt.xlabel('Width (px)')\n","plt.ylabel('Height (px)')\n","plt.title('Image Size Distribution')\n","plt.tight_layout()\n","plt.show()\n"]},{"cell_type":"code","execution_count":null,"metadata":{"id":"18-TjtkbUeys"},"outputs":[],"source":["# IMAGE SIZE ANALYSIS NOTES:\n","# - All images are very high resolution (avg ~3986x2702px) — raw camera quality\n","# - 8 different sizes found, aspect ratios also vary\n","# - Training on original resolution is computationally infeasible\n","# - DECISION: Resize all images to 224x224\n","#   Reason 1: Transfer learning models expect this input size\n","#   Reason 2: Reduces memory and computation significantly\n","#   Reason 3: Disease features (spots, texture) are spread across whole leaf\n","#             so direct resize is acceptable here"]},{"cell_type":"code","execution_count":null,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"elapsed":4271,"status":"ok","timestamp":1778229689795,"user":{"displayName":"ılgın güven","userId":"06815047185075290235"},"user_tz":-120},"id":"XUF41EcvUxJk","outputId":"cfb1ad78-4eda-4905-ff69-42442ae7932f"},"outputs":[{"name":"stdout","output_type":"stream","text":["Found 1322 images belonging to 3 classes.\n","Found 60 images belonging to 3 classes.\n","Found 150 images belonging to 3 classes.\n","Preprocessing pipeline ready!\n","\n","Input size:  (224, 224)\n","Batch size:  32\n","Class mapping: {'Healthy': 0, 'Powdery': 1, 'Rust': 2}\n","\n","Train batches per epoch: 41\n","Val batches:             1\n","Test batches:            4\n"]}],"source":["# ============================================================\n","# PREPROCESSING PIPELINE\n","# ============================================================\n","\n","# WHY IMAGENET NORMALIZATION:\n","# Transfer learning models (EfficientNet, ResNet) were trained on ImageNet\n","# using specific mean and std values per channel.\n","# Using the same normalization ensures pre-trained weights work correctly\n","# and leads to faster convergence and better performance.\n","# Simple 0-1 rescaling (rescale=1./255) is not enough for transfer learning.\n","\n","# WHY AUGMENTATION (train only):\n","# Dataset is small (1322 train images) — augmentation artificially increases variety.\n","# Applied ONLY to train set because we want to evaluate on real, unmodified images.\n","#   - Rotation: leaves can be photographed at any angle\n","#   - Horizontal flip: left/right orientation does not affect disease classification\n","#   - Zoom: some photos taken close up, some from far\n","#   - Brightness: photos taken in different lighting conditions,\n","#     especially important for Powdery class whose grey/white color varies with light\n","\n","import tensorflow as tf\n","from tensorflow.keras.preprocessing.image import ImageDataGenerator\n","from tensorflow.keras.applications.efficientnet import preprocess_input\n","\n","IMG_SIZE   = (224, 224)\n","BATCH_SIZE = 32\n","\n","# Train: augmentation + ImageNet normalization\n","train_datagen = ImageDataGenerator(\n","    preprocessing_function=preprocess_input,\n","    rotation_range=20,\n","    horizontal_flip=True,\n","    zoom_range=0.2,\n","    brightness_range=[0.8, 1.2],\n","    fill_mode='nearest'\n",")\n","\n","# Validation & Test: only ImageNet normalization, no augmentation\n","val_test_datagen = ImageDataGenerator(\n","    preprocessing_function=preprocess_input\n",")\n","\n","train_generator = train_datagen.flow_from_directory(\n","    train_dir,\n","    target_size=IMG_SIZE,\n","    batch_size=BATCH_SIZE,\n","    class_mode='categorical'\n",")\n","\n","val_generator = val_test_datagen.flow_from_directory(\n","    val_dir,\n","    target_size=IMG_SIZE,\n","    batch_size=BATCH_SIZE,\n","    class_mode='categorical'\n",")\n","\n","test_generator = val_test_datagen.flow_from_directory(\n","    test_dir,\n","    target_size=IMG_SIZE,\n","    batch_size=BATCH_SIZE,\n","    class_mode='categorical',\n","    shuffle=False  # keep order consistent for evaluation\n",")\n","\n","print(\"Preprocessing pipeline ready!\")\n","print(f\"\\nInput size:  {IMG_SIZE}\")\n","print(f\"Batch size:  {BATCH_SIZE}\")\n","print(f\"Class mapping: {train_generator.class_indices}\")\n","print(f\"\\nTrain batches per epoch: {train_generator.samples // BATCH_SIZE}\")\n","print(f\"Val batches:             {val_generator.samples // BATCH_SIZE}\")\n","print(f\"Test batches:            {test_generator.samples // BATCH_SIZE}\")"]},{"cell_type":"code","execution_count":null,"metadata":{"id":"a8clQN20WPsp"},"outputs":[],"source":["# NOTE — Validation set is very small (60 images, batch size 32 = only 1 full batch).\n","# This means validation results may not be fully reliable on their own.\n","# We will address this later with K-Fold Cross Validation,\n","# which splits the train set into k parts and rotates the validation fold,\n","# giving a much more reliable performance estimate."]},{"cell_type":"code","execution_count":null,"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":647},"executionInfo":{"elapsed":594,"status":"ok","timestamp":1778229690403,"user":{"displayName":"ılgın güven","userId":"06815047185075290235"},"user_tz":-120},"id":"lFkne-jYWSE4","outputI