","Epoch 16/30\n","\u001b[1m42/42\u001b[0m \u001b[32m━━━━━━━━━━━━━━━━━━━━\u001b[0m\u001b[37m\u001b[0m \u001b[1m332s\u001b[0m 8s/step - accuracy: 0.9160 - loss: 0.2629 - val_accuracy: 0.6500 - val_loss: 3.8515\n"]}],"source":["# TRAINING — Baseline CNN\n","# WHY EARLY STOPPING:\n","# Stops training when validation loss stops improving.\n","# Prevents overfitting and saves time.\n","\n","early_stopping = EarlyStopping(\n","    monitor='val_loss',\n","    patience=5,          # stop if no improvement for 5 epochs\n","    restore_best_weights=True\n",")\n","\n","baseline_history = baseline_model.fit(\n","    train_generator,\n","    epochs=30,\n","    validation_data=val_generator,\n","    callbacks=[early_stopping]\n",")"]},{"cell_type":"code","execution_count":null,"metadata":{"colab":{"background_save":true},"id":"wcThpOCpq5eh","outputId":"7cdd8446-9838-4aa8-ee7c-c34475517e79"},"outputs":[{"name":"stdout","output_type":"stream","text":["\u001b[1m5/5\u001b[0m \u001b[32m━━━━━━━━━━━━━━━━━━━━\u001b[0m\u001b[37m\u001b[0m \u001b[1m13s\u001b[0m 2s/step - accuracy: 0.9133 - loss: 0.5659\n","Test Accuracy: 0.9133\n","Test Loss:     0.5659\n","\u001b[1m5/5\u001b[0m \u001b[32m━━━━━━━━━━━━━━━━━━━━\u001b[0m\u001b[37m\u001b[0m \u001b[1m13s\u001b[0m 2s/step\n","\n","Classification Report:\n","              precision    recall  f1-score   support\n","\n","     Healthy       0.79      1.00      0.88        50\n","     Powdery       1.00      0.84      0.91        50\n","        Rust       1.00      0.90      0.95        50\n","\n","    accuracy                           0.91       150\n","   macro avg       0.93      0.91      0.92       150\n","weighted avg       0.93      0.91      0.92       150\n","\n"]},{"data":{"image/png":"\n","text/plain":["<Figure size 800x600 with 2 Axes>"]},"metadata":{},"output_type":"display_data"}],"source":["# ============================================================\n","# BASELINE MODEL EVALUATION\n","# ============================================================\n","\n","import numpy as np\n","from sklearn.metrics import classification_report, confusion_matrix\n","import seaborn as sns\n","\n","# Evaluate on test set\n","test_loss, test_acc = baseline_model.evaluate(test_generator)\n","print(f\"Test Accuracy: {test_acc:.4f}\")\n","print(f\"Test Loss:     {test_loss:.4f}\")\n","\n","# Predictions\n","test_generator.reset()\n","predictions = baseline_model.predict(test_generator)\n","predicted_classes = np.argmax(predictions, axis=1)\n","true_classes = test_generator.classes\n","class_labels = list(test_generator.class_indices.keys())\n","\n","# Classification report\n","print(\"\\nClassification Report:\")\n","print(classification_report(true_classes, predicted_classes, target_names=class_labels))\n","\n","# Confusion Matrix\n","cm = confusion_matrix(true_classes, predicted_classes)\n","plt.figure(figsize=(8, 6))\n","sns.heatmap(cm, annot=True, fmt='d', cmap='Blues',\n","            xticklabels=class_labels,\n","            yticklabels=class_labels)\n","plt.title('Baseline CNN — Confusion Matrix')\n","plt.ylabel('True Label')\n","plt.xlabel('Predicted Label')\n","plt.tight_layout()\n","plt.show()"]},{"cell_type":"code","execution_count":null,"metadata":{"colab":{"background_save":true},"id":"FkwlKwYprR3V"},"outputs":[],"source":["# BASELINE CNN RESULTS:\n","# Test Accuracy: 88% — surprisingly good for a model trained from scratch\n","#\n","# Confusion Matrix Analysis:\n","# - Healthy: almost perfect (49/50 correct)\n","# - Powdery: 8 misclassified as Healthy — confirms our EDA observation\n","#   that Powdery and Healthy are visually the most similar classes\n","# - Rust: 6 misclassified as Healthy, 0 as Powdery\n","#   Rust is never confused with Powdery — visually very different\n","#\n","# HOWEVER:\n","# - 25.7M parameters for 88% accuracy is very inefficient\n","# - High overfitting risk with this many parameters on small dataset\n","# - Transfer Learning should achieve better accuracy with fewer paramete