1b[32m━━━━━━━━━━━━━━━━━━━━\u001b[0m\u001b[37m\u001b[0m \u001b[1m176s\u001b[0m 4s/step - accuracy: 0.9841 - loss: 0.0483 - val_accuracy: 1.0000 - val_loss: 0.0185\n","Epoch 11/30\n","\u001b[1m42/42\u001b[0m \u001b[32m━━━━━━━━━━━━━━━━━━━━\u001b[0m\u001b[37m\u001b[0m \u001b[1m171s\u001b[0m 4s/step - accuracy: 0.9720 - loss: 0.0673 - val_accuracy: 1.0000 - val_loss: 0.0122\n","Epoch 12/30\n","\u001b[1m42/42\u001b[0m \u001b[32m━━━━━━━━━━━━━━━━━━━━\u001b[0m\u001b[37m\u001b[0m \u001b[1m168s\u001b[0m 4s/step - accuracy: 0.9818 - loss: 0.0544 - val_accuracy: 1.0000 - val_loss: 0.0134\n","Epoch 13/30\n","\u001b[1m42/42\u001b[0m \u001b[32m━━━━━━━━━━━━━━━━━━━━\u001b[0m\u001b[37m\u001b[0m \u001b[1m170s\u001b[0m 4s/step - accuracy: 0.9834 - loss: 0.0498 - val_accuracy: 1.0000 - val_loss: 0.0155\n","Epoch 14/30\n","\u001b[1m42/42\u001b[0m \u001b[32m━━━━━━━━━━━━━━━━━━━━\u001b[0m\u001b[37m\u001b[0m \u001b[1m176s\u001b[0m 4s/step - accuracy: 0.9879 - loss: 0.0380 - val_accuracy: 1.0000 - val_loss: 0.0114\n"]}],"source":["# TRAINING — EfficientNetB0\n","early_stopping = EarlyStopping(\n","    monitor='val_loss',\n","    patience=5,\n","    restore_best_weights=True\n",")\n","\n","efficientnet_history = efficientnet_model.fit(\n","    train_generator,\n","    epochs=30,\n","    validation_data=val_generator,\n","    callbacks=[early_stopping]\n",")"]},{"cell_type":"code","execution_count":null,"metadata":{"colab":{"background_save":true},"id":"H0IBWMRNV0ue"},"outputs":[],"source":["# EFFICIENTNETB0 TRAINING OBSERVATIONS:\n","# - Val accuracy reached 100% from epoch 6 onwards — baseline was never this stable\n","# - Train accuracy consistently above 97-99%\n","# - Val loss continuously decreasing — no signs of overfitting\n","# - Early stopping triggered at epoch 27\n","#\n","# COMPARISON SO FAR:\n","# - Baseline CNN: val accuracy fluctuating between 75-93%, unstable\n","# - EfficientNetB0: val accuracy stable at 100% from epoch 6\n","# - This stability comes from pre-trained ImageNet w